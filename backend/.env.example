# ===========================================================================
# ReCruItAI backend env — copy to backend/.env and fill in real values
# (backend/.env is gitignored)
# ===========================================================================

# ---------- LLM providers (at least one needed; OpenRouter recommended) ----
# OpenRouter is the default for interview engine + resume analysis.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional fallbacks (not required to boot — backend has lazy init)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ---------- TTS providers (default is gtts which needs no key) -------------
# Optional. If a key is set the corresponding provider auto-enables.
ELEVENLABS_API_KEY=
AZURE_SPEECH_KEY=
NVIDIA_API_KEY=

# ---------- Supabase (REQUIRED for Phase 3+) -------------------------------
# Project: redgbugvyoidjwhovmxa
# Dashboard: https://supabase.com/dashboard/project/redgbugvyoidjwhovmxa
#
# From Settings → API:
SUPABASE_URL=https://redgbugvyoidjwhovmxa.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# From Settings → API → JWT Settings → "JWT Secret"
SUPABASE_JWT_SECRET=

# From Settings → Database → Connection pooling → "Connection string"
# Use the POOLED connection string (port 6543), NOT the direct one (port 5432).
# Replace <REGION> with your project's region (e.g. ap-south-1) and <PASSWORD>
# with the database password you set when creating the project.
SUPABASE_DB_URL=postgresql://postgres.redgbugvyoidjwhovmxa:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres

# JWT verification (for FastAPI Supabase JWT dependency)
SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json
